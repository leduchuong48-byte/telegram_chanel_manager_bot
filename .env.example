# Telegram Bot API
TG_BOT_TOKEN=your_bot_token

# SQLite database path
DB_PATH=./data/bot.db

# Allowed chat IDs (comma-separated, empty means all chats)
ALLOW_CHAT_IDS=

# De-dup behavior
DELETE_DUPLICATES=0
DRY_RUN=1
KEEP_POLICY=oldest
RETRY_FAILED_DELETES=0
LOG_LEVEL=INFO

# Telethon (required for historical scan/tag tools)
TG_API_ID=
TG_API_HASH=
TG_SESSION=./sessions/user

# Tag processing
TAG_BUILD_LIMIT=0
TAG_COUNT=3
