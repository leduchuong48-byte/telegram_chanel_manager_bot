# Minimal environment file for container/runtime infrastructure only.
# Business settings are managed in config.json / Web UI.
# If these fields conflict with config.json, config.json wins.

# Optional: container log verbosity
LOG_LEVEL=INFO

# Optional: bot runtime compatibility only
# KEEP_POLICY is still read by legacy bot path; keep default unless needed.
KEEP_POLICY=oldest

# Optional: retry behavior for historical failed deletes in legacy bot path
RETRY_FAILED_DELETES=0

# Optional: legacy Telethon user session path for old scan/tag commands
TG_SESSION=./sessions/user

# Optional: legacy DB path for old bot path (normally keep default)
DB_PATH=./data/bot.db

# Optional: restrict old bot path to selected chats; leave empty for all
ALLOW_CHAT_IDS=

# Deprecated business fields intentionally omitted:
# TG_BOT_TOKEN
# TG_API_ID
# TG_API_HASH
# DRY_RUN
# DELETE_DUPLICATES
# TAG_COUNT
# TAG_BUILD_LIMIT
